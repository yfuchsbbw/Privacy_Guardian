<UserControl x:Class="PrivacyGuardian.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <UniformGrid Columns="2" Rows="3">
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="{Binding CpuUsageText}" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding CpuText}" FontSize="34" FontWeight="SemiBold" Margin="0,8" />
                    <ProgressBar Value="{Binding CpuUsage}" Maximum="100" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding RamUsageText}" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding RamText}" FontSize="34" FontWeight="SemiBold" Margin="0,8" />
                    <ProgressBar Value="{Binding RamUsage}" Maximum="100" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22" Margin="0,0,12,12">
                <StackPanel>
                    <TextBlock Text="{Binding DiskUsageText}" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding DiskText}" FontSize="34" FontWeight="SemiBold" Margin="0,8" />
                    <ProgressBar Value="{Binding DiskUsage}" Maximum="100" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{Binding NetworkUploadText}" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding NetworkUpload}" FontSize="34" FontWeight="SemiBold" Margin="0,8" />
                </StackPanel>
            </Border>
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="22" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="{Binding NetworkDownloadText}" Foreground="{DynamicResource MutedTextBrush}" />
                    <TextBlock Text="{Binding NetworkDownload}" FontSize="34" FontWeight="SemiBold" Margin="0,8" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
