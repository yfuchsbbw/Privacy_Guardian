<UserControl x:Class="PrivacyGuardian.Views.FileActivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:PrivacyGuardian.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Visibility="Collapsed" />
        <DataGrid Grid.Row="1" ItemsSource="{Binding Events}" RowStyle="{StaticResource SeverityRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="180" />
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120" />
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="3*" />
                <DataGridTextColumn Header="Old Path" Binding="{Binding OldPath}" Width="2*" />
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
