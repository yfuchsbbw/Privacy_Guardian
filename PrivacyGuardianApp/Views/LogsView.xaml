<UserControl x:Class="PrivacyGuardian.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:PrivacyGuardian.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Visibility="Collapsed" />
        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="{Binding FromDateText}" Foreground="{DynamicResource MutedTextBrush}" Margin="2,0,0,6" />
                    <DatePicker SelectedDate="{Binding FromDate}" SelectedDateFormat="Short" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="{Binding ToDateText}" Foreground="{DynamicResource MutedTextBrush}" Margin="2,0,0,6" />
                    <DatePicker SelectedDate="{Binding ToDate}" SelectedDateFormat="Short" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="{Binding SeverityText}" Foreground="{DynamicResource MutedTextBrush}" Margin="2,0,0,6" />
                    <ComboBox ItemsSource="{Binding Severities}" SelectedItem="{Binding SelectedSeverity}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="{Binding CategoryText}" Foreground="{DynamicResource MutedTextBrush}" Margin="2,0,0,6" />
                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="4" Style="{StaticResource ToolbarButtonStyle}" Content="{Binding RefreshText}" Command="{Binding RefreshCommand}" VerticalAlignment="Bottom" />
                <TextBlock Grid.Column="5" Text="{Binding Status}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Bottom" Margin="12,0,0,8" />
            </Grid>
        </Border>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Entries}" RowStyle="{StaticResource SeverityRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="180" />
                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="120" />
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140" />
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="2*" />
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="3*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
