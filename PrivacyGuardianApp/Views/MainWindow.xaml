<Window x:Class="PrivacyGuardian.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:PrivacyGuardian.Core"
        xmlns:viewModels="clr-namespace:PrivacyGuardian.ViewModels"
        xmlns:views="clr-namespace:PrivacyGuardian.Views"
        Title="{x:Static core:AppText.AppName}"
        Width="1320"
        Height="820"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ProcessesViewModel}">
            <views:ProcessesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:NetworkViewModel}">
            <views:NetworkView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PrivacyViewModel}">
            <views:PrivacyView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:StartupViewModel}">
            <views:StartupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:FileActivityViewModel}">
            <views:FileActivityView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:UsbViewModel}">
            <views:UsbView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:FirewallViewModel}">
            <views:FirewallView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Padding="20">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="{Binding AppName}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding MonitoringText}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,24" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateDashboardCommand}" Content="{Binding DashboardText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateProcessesCommand}" Content="{Binding ProcessesText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateNetworkCommand}" Content="{Binding NetworkText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigatePrivacyCommand}" Content="{Binding PrivacyText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateStartupCommand}" Content="{Binding StartupText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateFileActivityCommand}" Content="{Binding FileActivityText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateUsbCommand}" Content="{Binding UsbText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateFirewallCommand}" Content="{Binding FirewallText}" />
                    <Button Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateLogsCommand}" Content="{Binding LogsText}" />
                </StackPanel>
                <Button DockPanel.Dock="Bottom" Style="{StaticResource NavigationButtonStyle}" Command="{Binding NavigateSettingsCommand}" Content="{Binding SettingsText}" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,18">
                <Border DockPanel.Dock="Right" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8">
                    <TextBlock Text="{Binding CurrentStatus}" Foreground="{DynamicResource MutedTextBrush}" />
                </Border>
                <TextBlock Text="{Binding CurrentTitle}" FontSize="30" FontWeight="SemiBold" VerticalAlignment="Center" />
            </DockPanel>

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" />

            <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,16,0,0">
                <TextBlock Text="{Binding MonitoringText}" Foreground="{DynamicResource MutedTextBrush}" />
            </Border>
        </Grid>
    </Grid>
</Window>
