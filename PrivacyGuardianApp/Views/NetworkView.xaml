<UserControl x:Class="PrivacyGuardian.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:PrivacyGuardian.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Visibility="Collapsed" />
        <DockPanel Grid.Row="1" Margin="0,0,0,14">
            <Button DockPanel.Dock="Right" Content="{Binding RefreshText}" Command="{Binding RefreshCommand}" />
            <TextBlock Text="{Binding Status}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
        </DockPanel>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Connections}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="160" />
                <DataGridTextColumn Header="Protocol" Binding="{Binding Protocol}" Width="80" />
                <DataGridTextColumn Header="Local IP" Binding="{Binding LocalIp}" Width="140" />
                <DataGridTextColumn Header="Remote IP" Binding="{Binding RemoteIp}" Width="140" />
                <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="100" />
                <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="2*" />
                <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="80" />
                <DataGridTextColumn Header="Upload" Binding="{Binding UploadBytesPerSecond, Converter={StaticResource BytesConverter}}" Width="100" />
                <DataGridTextColumn Header="Download" Binding="{Binding DownloadBytesPerSecond, Converter={StaticResource BytesConverter}}" Width="110" />
                <DataGridTemplateColumn Header="Action" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DataContext.BlockText, RelativeSource={RelativeSource AncestorType=DataGrid}}" Command="{Binding DataContext.BlockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
