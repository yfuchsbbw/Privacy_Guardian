<UserControl x:Class="PrivacyGuardian.Views.ProcessesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:PrivacyGuardian.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Visibility="Collapsed" />
        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding SearchTextLabel}" Foreground="{DynamicResource MutedTextBrush}" Margin="2,0,0,6" />
                <TextBox Grid.Row="1" Style="{StaticResource CompactTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Status}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="14,0,0,0" />
                <Border Grid.Column="2" Grid.Row="1" Background="#5530141A" BorderBrush="{DynamicResource CriticalBrush}" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="8,0,0,0">
                    <TextBlock Text="Suspicious" Foreground="{DynamicResource CriticalBrush}" FontWeight="SemiBold" />
                </Border>
                <Button Grid.Column="3" Grid.Row="1" Style="{StaticResource ToolbarButtonStyle}" Content="{Binding RefreshText}" Command="{Binding RefreshCommand}" />
            </Grid>
        </Border>
        <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredProcesses}" RowStyle="{StaticResource SuspiciousProcessRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Process Name" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="80" />
                <DataGridTextColumn Header="Memory" Binding="{Binding MemoryBytes, Converter={StaticResource BytesConverter}}" Width="120" />
                <DataGridTextColumn Header="CPU" Binding="{Binding CpuUsage, StringFormat={}{0:0.0}%}" Width="90" />
                <DataGridTextColumn Header="Digital Signature" Binding="{Binding DigitalSignature}" Width="130" />
                <DataGridTextColumn Header="Company" Binding="{Binding Company}" Width="180" />
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime}" Width="160" />
                <DataGridTextColumn Header="Signal" Binding="{Binding SuspicionReason}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
