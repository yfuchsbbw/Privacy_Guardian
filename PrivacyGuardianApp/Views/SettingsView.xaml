<UserControl x:Class="PrivacyGuardian.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:PrivacyGuardian.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Visibility="Collapsed" />
        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" MaxWidth="560" HorizontalAlignment="Left">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <CheckBox Content="{Binding DarkModeText}" IsChecked="{Binding IsDarkMode}" />
                    <CheckBox Content="{Binding NotificationsText}" IsChecked="{Binding NotificationsEnabled}" />
                    <CheckBox Content="{Binding AutoStartText}" IsChecked="{Binding AutoStartEnabled}" />
                    <CheckBox Content="{Binding RunInBackgroundText}" IsChecked="{Binding RunInBackgroundOnClose}" />
                    <CheckBox Content="{Binding AutoUpdateText}" IsChecked="{Binding AutoUpdateEnabled}" />
                    <CheckBox Content="{Binding AutoInstallUpdatesText}" IsChecked="{Binding AutoInstallUpdates}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <TextBlock Text="{Binding LanguageText}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Language}" Width="180" HorizontalAlignment="Left" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <TextBlock Text="{Binding UpdateManifestUrlText}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,6" />
                    <TextBox Style="{StaticResource CompactTextBoxStyle}" Text="{Binding UpdateManifestUrl, UpdateSourceTrigger=PropertyChanged}" Width="420" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,10,0,0" />
                </StackPanel>

                <Button Grid.Row="3" Style="{StaticResource ToolbarButtonStyle}" Content="{Binding SaveSettingsText}" Command="{Binding SaveCommand}" HorizontalAlignment="Left" Margin="0,18,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
