<UserControl x:Class="PrivacyGuardian.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:PrivacyGuardian.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Visibility="Collapsed" />
        <DockPanel Grid.Row="1" Margin="0,0,0,14">
            <Button DockPanel.Dock="Right" Content="{Binding RefreshText}" Command="{Binding RefreshCommand}" />
            <TextBlock Text="{Binding Status}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
        </DockPanel>
        <DataGrid Grid.Row="2" ItemsSource="{Binding Entries}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="150" />
                <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="3*" />
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="90" />
                <DataGridTemplateColumn Header="Action" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DataContext.DisableText, RelativeSource={RelativeSource AncestorType=DataGrid}}" Command="{Binding DataContext.DisableCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
