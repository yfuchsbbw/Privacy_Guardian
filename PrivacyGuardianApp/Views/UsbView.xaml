<UserControl x:Class="PrivacyGuardian.Views.UsbView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:PrivacyGuardian.Core">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" Visibility="Collapsed" />
        <DataGrid Grid.Row="1" ItemsSource="{Binding Events}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="180" />
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120" />
                <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="180" />
                <DataGridTextColumn Header="Product" Binding="{Binding Product}" Width="180" />
                <DataGridTextColumn Header="Serial Number" Binding="{Binding SerialNumber}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
